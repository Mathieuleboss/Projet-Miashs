import numpy as np
import math

PERLIN_SIZE = 1024
PERLIN_SCALE = 32
PERSISTENCE = 0.9
LACUNARITY = 3.0
NUM_OCTAVES = 10

def generate_perlin_noise_table():
    """Generate a table of Perlin noise values."""
    perlin[:] = np.random.random((PERLIN_SIZE, PERLIN_SIZE))

def perlin_noise(x, y, z, octave):
    """Calculate the Perlin noise value for a given position."""
    x0 = math.floor(x)
    x1 = x0 + 1
    y0 = math.floor(y)
    y1 = y0 + 1
    z0 = math.floor(z)
    z1 = z0 + 1
    sx = x - x0
    sy = y - y0
    sz = z - z0

    n000 = perlin[x0 & (PERLIN_SIZE - 1)][y0 & (PERLIN_SIZE - 1)]
    n001 = perlin[x0 & (PERLIN_SIZE - 1)][y1 & (PERLIN_SIZE - 1)]
    n010 = perlin[x1 & (PERLIN_SIZE - 1)][y0 & (PERLIN_SIZE - 1)]
    n011 = perlin[x1 & (PERLIN_SIZE - 1)][y1 & (PERLIN_SIZE - 1)]
    n100 = perlin[x0 & (PERLIN_SIZE - 1)][z0 & (PERLIN_SIZE - 1)]
    n101 = perlin[x0 & (PERLIN_SIZE - 1)][z1 & (PERLIN_SIZE - 1)]
    n110 = perlin[x1 & (PERLIN_SIZE - 1)][z0 & (PERLIN_SIZE - 1)]
    n111 = perlin[x1 & (PERLIN_SIZE - 1)][z1 & (PERLIN_SIZE - 1)]

