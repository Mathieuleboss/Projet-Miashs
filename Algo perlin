def generate_terrain():
    """Generate a terrain using Perlin noise."""
    terrain = np.zeros((PERLIN_SIZE, PERLIN_SIZE))
    amplitude = 1
    frequency = 1
    for octave in range(NUM_OCTAVES):
        for x in range(PERLIN_SIZE):
            for y in range(PERLIN_SIZE):
                noise = perlin_noise(x / PERLIN_SCALE * frequency, y / PERLIN_SCALE * frequency, 0, octave)
                terrain[x][y] += noise * amplitude
        amplitude *= PERSISTENCE
        frequency *= LACUNARITY
    return terrain

def generate_biomes(terrain):
    """Generate biomes based on the terrain height."""
    biomes = np.zeros((PERLIN_SIZE, PERLIN_SIZE))
    for x in range(PERLIN_SIZE):
        for y in range(PERLIN_SIZE):
            height = terrain[x][y]
            if height < 0.2:
                biomes[x][y] = 0  # Water
            elif height < 0.4:
                biomes[x][y] = 1  # Beach
            elif height < 0.6:
                biomes[x][y] = 2  # Grassland
            elif height < 0.8:
                biomes[x][y] = 3  # Forest
            else:
                biomes[x][y] = 4  # Mountain
    return biomes

import matplotlib.pyplot as plt

def display_map(terrain, biomes):
    """Display the map in 2D using Matplotlib."""
    plt.imshow(terrain, cmap='viridis')
    plt.colorbar()
    plt.imshow(biomes, cmap='viridis', alpha=0.5)
    plt.show()

generate_perlin_noise_table()
terrain = generate_terrain()
biomes = generate_biomes(terrain)
display_map(terrain, biomes)
