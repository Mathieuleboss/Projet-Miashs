import tkinter as tk
from tkinter import filedialog
import generator

class MapGeneratorGUI:
    def __init__(self, master):
        self.master = master
        self.master.title("Générateur de carte")

        # Création du menu
        menubar = tk.Menu(self.master)
        self.master.config(menu=menubar)

        # Sous-menu "Fichier"
        filemenu = tk.Menu(menubar, tearoff=0)
        menubar.add_cascade(label="Fichier", menu=filemenu)
        filemenu.add_command(label="Enregistrer la carte", command=self.save_map)
        filemenu.add_command(label="Exporter la carte", command=self.export_map)
        filemenu.add_command(label="Quitter", command=self.master.quit)

        # Création du canvas pour afficher la carte
        self.canvas = tk.Canvas(self.master, width=800, height=600)
        self.canvas.pack()

        # Création des widgets pour les paramètres de génération de carte
        self.size_label = tk.Label(self.master, text="Taille de la carte :")
        self.size_entry = tk.Entry(self.master, width=10)
        self.size_entry.insert(0, "50")
        self.climate_label = tk.Label(self.master, text="Climat :")
        self.climate_entry = tk.Entry(self.master, width=10)
        self.climate_entry.insert(0, "0.5")
        self.relief_label = tk.Label(self.master, text="Relief :")
        self.relief_entry = tk.Entry(self.master, width=10)
        self.relief_entry.insert(0, "0.5")
        self.density_label = tk.Label(self.master, text="Densité de population :")
        self.density_entry = tk.Entry(self.master, width=10)
        self.density_entry.insert(0, "0.5")
        self.generate_button = tk.Button(self.master, text="Générer la carte", command=self.generate_map)

        # Positionnement des widgets
        self.size_label.place(x=10, y=10)
        self.size_entry.place(x=120, y=10)
        self.climate_label.place(x=10, y=40)
        self.climate_entry.place(x=120, y=40)
        self.relief_label.place(x=10, y=70)
        self.relief_entry.place(x=120, y=70)
        self.density_label.place(x=10, y=100)
        self.density_entry.place(x=120, y=100)
        self.generate_button.place(x=10, y=130)

    def generate_map(self):
        size = int(self.size_entry.get())
        climate = float(self.climate_entry.get())
        relief = float(self.relief_entry.get())
        density = float(self.density_entry.get())
        map_data = generator.generate_map(size, climate, relief, density)
        self.display_map(map_data)

    def display_map(self, map_data):
        self.canvas.delete("all")
        for i in range(len(map_data)):
            for j in range(len(map_data[i])):
                color = generator.get_color(map_data[i][j])
                x1, y1 = j, i
                x2, y2 = j + 1, i + 1
                self.canvas.create_rectangle(x1, y1, x2, y2, fill=color)

    def save_map(self):
        file_path = filedialog.asksaveasfilename(defaultextension=".csv")
        map_data = self.get_map_data()
        generator.save_map(map_data, file_path)

    def export_map(self):
        file_path = filedialog.asksaveasfilename(defaultextension=".png")
        map_data = self.get_map_data()
        generator.export_map(map_data, file_path)

    def get_map_data(self):
        size = int(self.size_entry.get())
        map_data = []
        for i in range(size):
            row = []
            for j in range(size):
                x1, y1 = j, i
                x2, y2 = j + 1, i + 1
                color = self.canvas.find_closest(x1, y1, x2, y2)[2]
                biome = generator.get_biome_from_color(color)
                row.append(biome)
            map_data.append(row)
        return map_data

root = tk.Tk()
app = MapGeneratorGUI(root)
root.mainloop()
