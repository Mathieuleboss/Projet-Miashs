import numpy as np
import matplotlib.pyplot as plt
import tkinter as tk
from tkinter import ttk
from tkinter import filedialog
from matplotlib.backends.backend_tkagg import FigureCanvasTkAgg

def generate_terrain_map(width, height, mountain_density, forest_density, lake_density):
    terrain_map = np.zeros((height, width), dtype=int)

    # Générer les montagnes
    mountain_map = np.random.rand(height, width) < mountain_density
    terrain_map[mountain_map] = 1

    # Générer les forêts
    forest_map = np.random.rand(height, width) < forest_density
    terrain_map[(forest_map & ~mountain_map)] = 2

    # Générer les lacs
    lake_map = np.random.rand(height, width) < lake_density
    terrain_map[(lake_map & ~mountain_map & ~forest_map)] = 3

    return terrain_map

def display_terrain_map(terrain_map):
    colors = ['white', 'brown', 'green', 'blue']
    fig, ax = plt.subplots()
    ax.imshow(terrain_map, cmap=colors)
    return fig

def save_terrain_map(terrain_map):
    colors = ['white', 'brown', 'green', 'blue']
    fig = plt.figure()
    plt.imshow(terrain_map, cmap=colors)
    file_path = filedialog.asksaveasfilename(defaultextension=".png")
    fig.savefig(file_path)
    plt.close(fig)

def generate_map():
    width = int(width_entry.get())
    height = int(height_entry.get())
    mountain_density = float(mountain_density_entry.get())
    forest_density = float(forest_density_entry.get())
    lake_density = float(lake_density_entry.get())

    terrain_map = generate_terrain_map(width, height, mountain_density, forest_density, lake_density)
    fig = display_terrain_map(terrain_map)
    canvas = FigureCanvasTkAgg(fig, master=root)
    canvas.draw()
    canvas.get_tk_widget().pack(side=tk.TOP, fill=tk.BOTH, expand=1)
    save_terrain_map(terrain_map)

